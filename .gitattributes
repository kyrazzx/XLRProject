* text=auto eol=lf

# Force LF on all text-like files (prevents CRLF on Linux VPS after git pull)
*.sh text eol=lf
*.bash text eol=lf
*.py text eol=lf
*.json text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.cfg text eol=lf
*.gsc text eol=lf
*.txt text eol=lf
*.service text eol=lf
*.editorconfig text eol=lf
*.gitattributes text eol=lf
*.gitignore text eol=lf

xlr-update.sh text eol=lf
xlr-configure.sh text eol=lf
install.sh text eol=lf
uninstall.sh text eol=lf
import-game-files.sh text eol=lf
install-plutonium.sh text eol=lf

